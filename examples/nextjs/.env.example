# Copy to .env.local and fill in your values.
# Testnet defaults work out of the box — no changes needed to get started.

# Stellar network (testnet | mainnet)
NEXT_PUBLIC_NETWORK=testnet

# Factory contract deployed on Stellar testnet
NEXT_PUBLIC_FACTORY_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4

# Soroban RPC endpoint
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Horizon REST API endpoint
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
