# Stellar network configuration
EXPO_PUBLIC_FACTORY_ADDRESS=CABC...  # Your factory contract address
EXPO_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org
EXPO_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# WebAuthn relying party — must match your app's associated domain
# iOS: set in apple-app-site-association
# Android: set in assetlinks.json
EXPO_PUBLIC_RP_ID=veil.app
EXPO_PUBLIC_ORIGIN=https://veil.app