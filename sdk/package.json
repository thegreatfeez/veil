{
  "name": "invisible-wallet-sdk",
  "version": "0.1.0",
  "description": "Client SDK for Invisible Wallet (Soroban + WebAuthn) — supports Web and React Native",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "react-native": "src/index.ts",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types":        "./dist/index.d.ts",
      "react-native": "./src/index.ts",
      "default":      "./dist/index.js"
    },
    "./vanilla": {
      "types":        "./dist/vanilla.d.ts",
      "react-native": "./src/vanilla.ts",
      "default":      "./dist/vanilla.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest"
  },
  "keywords": [
    "stellar",
    "soroban",
    "webauthn",
    "passkeys",
    "wallet",
    "react-native",
    "expo"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@stellar/stellar-sdk": "^14.6.1"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-native": ">=0.72.0",
    "react-native-passkey": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "react-native-passkey": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "setupFiles": ["./jest.setup.ts"],
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^@stellar/stellar-sdk$": "<rootDir>/node_modules/@stellar/stellar-sdk"
    },
    "globals": {
      "ts-jest": {
        "tsconfig": {
          "strict": true,
          "esModuleInterop": true,
          "skipLibCheck": true
        }
      }
    }
  }
}