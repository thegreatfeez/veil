{
  "name": "invisible-wallet-sdk",
  "version": "0.1.0",
  "description": "Client SDK for Invisible Wallet (Soroban + WebAuthn)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest"
  },
  "keywords": [
    "stellar",
    "soroban",
    "webauthn",
    "passkeys",
    "wallet"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@stellar/stellar-sdk": "^14.6.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "setupFiles": ["<rootDir>/jest.setup.js"],
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^@stellar/stellar-sdk$": "<rootDir>/node_modules/@stellar/stellar-sdk"
    },
    "globals": {
      "ts-jest": {
        "tsconfig": {
          "strict": true,
          "esModuleInterop": true,
          "skipLibCheck": true
        }
      }
    }
  }
}
