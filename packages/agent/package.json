{
  "name": "@veil/agent",
  "version": "0.2.0",
  "description": "Veil AI agent — Claude-powered wallet assistant with x402 Stellar payments",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.cjs"
  },
  "keywords": [
    "stellar",
    "soroban",
    "ai-agent",
    "claude",
    "x402",
    "veil"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.81.0",
    "@soroswap/sdk": "^0.4.0",
    "@stellar/stellar-sdk": "^14.6.1",
    "@x402/core": "^2.13.0",
    "@x402/stellar": "^2.11.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.12",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.22.3",
    "typescript": "^5.0.0"
  }
}
